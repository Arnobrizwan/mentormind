{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npx ng build student-portal --configuration production",
  "outputDirectory": "frontend/dist/student-portal/browser",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
