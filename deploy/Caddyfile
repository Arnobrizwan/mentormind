# Automatic HTTPS via Let's Encrypt for the API domain.
# Caddy provisions + renews the certificate and forwards plain HTTP to the
# backend, setting X-Forwarded-Proto: https (which Django trusts).
# Websockets (the Channels chat) pass through reverse_proxy transparently.

{$API_DOMAIN} {
	encode zstd gzip

	# Cap request bodies (proctor frames / OCR images are a few MB at most).
	request_body {
		max_size 12MB
	}

	# Backend handles the API, Django admin/static/media, metrics and the
	# Channels websocket; everything else is the student-portal SPA.
	@backend path /api/* /admin/* /static/* /media/* /metrics /ws/*
	reverse_proxy @backend backend:8000 {
		# Long-lived upgrade for the websocket chat.
		flush_interval -1
	}
	reverse_proxy frontend:80

	log {
		output stdout
		format console
	}
}
