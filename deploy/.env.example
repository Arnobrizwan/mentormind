# MentorMind production deploy — copy to .env and fill in.
#   cp .env.example .env
#
# Generate strong secrets:
#   SECRET_KEY:   python -c "import secrets; print(secrets.token_urlsafe(64))"
#   DB_PASSWORD:  python -c "import secrets; print(secrets.token_urlsafe(24))"
#   ML_API_KEY:   python -c "import secrets; print(secrets.token_urlsafe(24))"

# --- Domain (point an A record at the VPS IP first) -----------------------
# The API is served here; the certificate is issued for this exact host.
API_DOMAIN=api.yourdomain.com

# --- Secrets (REQUIRED — the backend refuses to boot without a real key) --
SECRET_KEY=replace-with-64-char-random-string
DB_PASSWORD=replace-with-strong-db-password
# Shared key the backend sends to the ml-service as X-API-Key. Any random
# string — just keep backend and ml-service in sync (they are, via this file).
ML_API_KEY=replace-with-random-ml-key

# --- Frontend origins allowed to call the API (your Vercel URLs) ----------
# Comma-separated, no trailing slash, include scheme.
CORS_ALLOWED_ORIGINS=https://mentormind-demo.vercel.app,https://mentormind-studio.vercel.app

# --- Tutor corpus (255 MB, not in git) ------------------------------------
# Option A (recommended): download from your private Hugging Face dataset on
# first boot. Create a READ token at https://huggingface.co/settings/tokens
DATASET_REPO=ARNOB666666/mentormind-corpus
HF_TOKEN=hf_replace_with_your_read_token

# Option B: leave DATASET_REPO/HF_TOKEN blank and scp the DB into the volume:
#   docker compose cp ../ml-service/pastpapers.db ml-service:/data/pastpapers.db
#   docker compose restart ml-service

# --- Optional: object storage for uploads (Cloudflare R2 / S3) ------------
# Leave unset to keep uploads on the local media volume.
# R2_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=mentormind

# --- Optional: real email (defaults to console/no-op) ---------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=MentorMind <no-reply@yourdomain.com>

# --- Optional: PWA web-push reminders (self-hosted VAPID, no paid service) -
# Generate once on the box:  docker compose run --rm backend \
#   python manage.py generate_vapid_keys
# Then paste both keys here and `docker compose up -d` to enable the opt-in.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com
