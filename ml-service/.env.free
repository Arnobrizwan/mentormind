# =============================================================================
# MentorMinds ML service — FREE TIER (copy to ml-service/.env)
#   cp ml-service/.env.free ml-service/.env
#
# Tutor: retrieval over local/SQLite corpus — no OpenAI, no paid GPU.
# OCR ingest: pypdf text layer (free). Tesseract for photo OCR at runtime.
# Does NOT use: MISTRAL_API_KEY, CUSTOM_LLM_URL, or cloud LLM APIs.
# =============================================================================

# --- Auth (match backend ML_API_KEY and HF Space secret) ---
ML_API_KEY=mentormind-public-demo-ml-key

# Local dev only — NEVER on public HF Space:
# ML_ALLOW_UNAUTHENTICATED=1

# --- Corpus: SQLite on disk (free). Ships with pastpapers.db or download from HF dataset. ---
PASTPAPERS_DB_URL=sqlite+aiosqlite:///./pastpapers.db

# --- Do NOT set these (paid / optional upgrades) ---
# MISTRAL_API_KEY=          # paid OCR for scanned PDFs — pypdf is free default
# CUSTOM_LLM_URL=             # self-hosted vLLM/Ollama — optional, still free if local
# OPENAI_API_KEY=             # not used anywhere

# --- HF Space only: download private corpus dataset ---
# HF_TOKEN=hf_xxxxxxxx
# DATASET_REPO=ARNOB666666/mentormind-corpus

# --- Feature flags from Django (optional; fail-open if unreachable) ---
# FLAGS_URL=https://mentormind-api.onrender.com/api/v1/flags/
