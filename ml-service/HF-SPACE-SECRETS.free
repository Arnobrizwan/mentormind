# Hugging Face Space → Settings → Variables (free CPU Basic)
# Copy each line as KEY=VALUE. No paid APIs required.

ML_API_KEY=mentormind-public-demo-ml-key

# Download private corpus at container boot (free HF account + read token):
# HF_TOKEN=<your huggingface read token>
# DATASET_REPO=ARNOB666666/mentormind-corpus

# Leave UNSET for free tier (code uses free fallbacks):
# MISTRAL_API_KEY     → pypdf text extraction instead
# CUSTOM_LLM_URL      → corpus retrieval instead of external LLM
# OPENAI_API_KEY      → not used
