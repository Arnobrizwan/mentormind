# ── MentorMind ML service configuration ────────────────────────────────
# >>> FASTEST FREE SETUP: cp .env.free .env
#
# All OPTIONAL. The service runs fully offline with no keys:
#  - past-paper OCR uses local pypdf text extraction (no Mistral API)
#  - the tutor answers from the local aligned corpus + an optional
#    in-process fine-tuned model (no OpenAI / Anthropic / paid GPU)
# HF Space secrets template: HF-SPACE-SECRETS.free

# --- Auth: required in any deployed environment --------------------------
# Every inference/pipeline endpoint requires X-API-Key == ML_API_KEY.
# Unset = 503 on those routes, unless you explicitly opt in for local dev.
# ML_API_KEY=change-me
# ML_ALLOW_UNAUTHENTICATED=1     # local dev ONLY — never set in production

# --- Answer ANY relevant question -----------------------------------------
# The tutor returns the real mark scheme on a strong corpus match; otherwise
# it falls back to the configured model to answer generally. Off-corpus
# answers therefore need a model — pick ONE of the options below. With none,
# the tutor stays corpus-only (still works, just narrower).

# --- Option A: fully-offline IN-PROCESS model (no server, no network) ------
# LOCAL_LLM=1
# Qwen-0.5B is the tiny default; Gemma answers general questions far better.
# LOCAL_LLM_BASE=Qwen/Qwen2.5-0.5B-Instruct        # default — small, ~1 GB RAM
# LOCAL_LLM_BASE=google/gemma-2-2b-it              # recommended — ~5 GB RAM, free weights
# LOCAL_LLM_ADAPTER=./models/tutor-lora            # optional fine-tuned LoRA (used if present)
# LOCAL_LLM_MAX_TOKENS=512

# --- Option B: OpenAI-compatible server (local Ollama/vLLM, or a FREE host) -
# Local (still offline):   ollama run gemma2  ->  CUSTOM_LLM_URL=http://localhost:11434/v1
# CUSTOM_LLM_URL=http://localhost:8000
# CUSTOM_LLM_MODEL=gemma2
# Free hosted gateways (have free tiers; data leaves your server — opt-in):
#   Google AI Studio (Gemini/Gemma):  https://generativelanguage.googleapis.com/v1beta/openai
#   Groq:                             https://api.groq.com/openai/v1     (model: gemma2-9b-it)
#   OpenRouter free models:           https://openrouter.ai/api/v1       (model: google/gemma-2-9b-it:free)
# CUSTOM_LLM_API_KEY=                              # bearer token for the hosted gateway, if any

# --- Past-paper pipeline ------------------------------------------------
# PASTPAPERS_DB_URL=sqlite+aiosqlite:///./pastpapers.db   # or postgresql+asyncpg://...
# PASTPAPERS_MARKDOWN_DIR=./data/markdown
# PASTPAPERS_SYSTEM_PROMPT="You are an expert Cambridge tutor..."

# --- OPTIONAL: upgrade OCR to Mistral for SCANNED papers (LaTeX math).
#     Digital papers need nothing — pypdf reads them offline.
# MISTRAL_API_KEY=
# MISTRAL_OCR_MODEL=mistral-ocr-latest

# --- Feature flags from the platform (fail-open if unreachable) ---------
# FLAGS_URL=http://nginx/api/v1/flags/
# FLAGS_TTL_SECONDS=30
