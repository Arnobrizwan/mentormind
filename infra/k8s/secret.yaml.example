# EXAMPLE ONLY — not applied by kustomize and must never hold real values.
#
# Real secrets are produced by the secretGenerator in kustomization.yaml
# from an untracked `secrets.env` file:
#
#   cp secrets.env.example secrets.env   # then fill in real values
#   kubectl apply -k .
#
# This file is kept solely to show the equivalent raw-Secret shape for
# people wiring up external-secrets / sealed-secrets instead.
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: mentormind
type: Opaque
stringData:
  SECRET_KEY: change-me-in-real-clusters
  DATABASE_URL: postgres://mentormind:change-me@postgres:5432/mentormind
  POSTGRES_PASSWORD: change-me
  ML_API_KEY: change-me
