# Template — replace values (or create via `kubectl create secret` /
# external-secrets) before applying to anything shared.
apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: mentormind
type: Opaque
stringData:
  SECRET_KEY: change-me-in-real-clusters
  DATABASE_URL: postgres://mentormind:mentormind@postgres:5432/mentormind
