# Copy to secrets.env (same directory) and fill in real values before
# `kubectl apply -k .` — kustomization.yaml feeds this file to the
# backend-secrets secretGenerator.
#
# secrets.env is gitignored (see infra/k8s/.gitignore). NEVER commit it.
#
# Keep POSTGRES_PASSWORD and the password embedded in DATABASE_URL in sync.

SECRET_KEY=replace-with-a-long-random-django-secret
DATABASE_URL=postgres://mentormind:replace-with-db-password@postgres:5432/mentormind
POSTGRES_PASSWORD=replace-with-db-password
ML_API_KEY=replace-with-shared-ml-service-key
