{
  "uid": "mentormind-overview",
  "title": "MentorMind Overview",
  "tags": ["mentormind"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Django request rate (req/s by method)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method) (rate(django_http_requests_total_by_method_total{service=\"django-api\"}[5m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Django latency p95 / p50 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_bucket{service=\"django-api\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(django_http_requests_latency_seconds_by_view_method_bucket{service=\"django-api\"}[5m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "ML service request rate (req/s by handler)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (rate(http_requests_total{service=\"ml-service\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "ML service error rate (non-2xx req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_requests_total{service=\"ml-service\", status!~\"2xx\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1
}
