# Copy to .env for local development. Every value is environment-driven — no hardcode.
#
# >>> FASTEST FREE SETUP: cp .env.free .env  (or: bash ../scripts/setup-free-tier.sh)
#     Uses SQLite + in-memory cache — no Postgres, Redis, Stripe, or OpenAI.
#
# EVERY value here is OPTIONAL — the app runs with zero config on a laptop
# (SQLite, in-memory cache, console email, eager Celery, offline tutor).
# No external or paid API keys are required anywhere.
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=*
INSTANCE_NAME=api-local

# Postgres primary (writes). Falls back to sqlite if unset.
# DATABASE_URL=postgres://mentormind:mentormind@localhost:5432/mentormind
# Postgres read replica (reads). Optional — enables the read/write router.
# REPLICA_URL=postgres://mentormind:mentormind@localhost:5433/mentormind

# Redis: cache + Celery broker + Channels. Falls back to in-memory + eager tasks if unset.
# REDIS_URL=redis://localhost:6379/0

# CORS_ALLOWED_ORIGINS=http://localhost:4200,https://localhost,capacitor://localhost

# --- AI tutor (fully self-hosted — NO external AI provider) ---
# TUTOR_MODEL_URL=http://localhost:9000/v1/tutor/answer
# ML_SERVICE_URL=http://localhost:9000
# Shared secret for the ml-service (sent as X-API-Key on every call)
# ML_API_KEY=
# TUTOR_MODEL_TIMEOUT_SECONDS=15

# --- Auth token lifetimes / pagination (tunable) ---
# JWT_ACCESS_MINUTES=30
# JWT_REFRESH_DAYS=7
# API_PAGE_SIZE=20
# PASSWORD_MIN_LENGTH=10

# --- Production hardening (enforced automatically when DEBUG=False) ---
# With DEBUG off, a real SECRET_KEY and explicit ALLOWED_HOSTS are REQUIRED
# (the process refuses to boot otherwise), and HTTPS redirect, HSTS and
# secure cookies switch on. Override the transport bits only behind a proxy
# that already terminates TLS:
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# --- Rate limiting (per IP / per user) ---
# THROTTLE_ANON=60/min
# THROTTLE_USER=240/min
# THROTTLE_AUTH=10/min

# --- Scaling ---
# WEB_CONCURRENCY=4        # gunicorn worker processes (set to ~2×vCPU)
# DB_CONN_MAX_AGE=600      # persistent DB connections (seconds)

# --- Object storage: local disk by default. Set for Cloudflare R2 / S3 (your own creds). ---
# R2_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=mentormind

# --- Email: console backend by default. Set for real SMTP (your provider). ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=MentorMind <no-reply@yourdomain.com>

# --- PWA web-push reminders (optional, OFF by default). Self-hosted VAPID —
#     no FCM/APNs paid service. Generate a keypair:
#       python manage.py generate_vapid_keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com
# REMINDER_HOUR=18         # local hour the daily "cards due" push goes out
