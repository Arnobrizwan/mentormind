# =============================================================================
# MentorMinds — FREE TIER (copy to backend/.env)
#   cp backend/.env.free backend/.env
#
# Uses: SQLite, in-memory cache, in-memory Channels, eager Celery, console email.
# Does NOT use: Postgres, Redis, Stripe, OpenAI, or any paid API.
# =============================================================================

SECRET_KEY=dev-only-change-for-production
DEBUG=True
ALLOWED_HOSTS=*
INSTANCE_NAME=api-local

# --- Database: SQLite (default). Do NOT set DATABASE_URL or REPLICA_URL. ---
# Postgres is optional for production scale only.

# --- Cache / chat / tasks: in-memory (default). Do NOT set REDIS_URL. ---
# Redis is optional for multi-instance / production only.

# --- AI tutor: self-hosted ml-service (HF Space or local). No OpenAI. ---
ML_SERVICE_URL=https://arnob666666-mentormind-ml.hf.space
TUTOR_MODEL_URL=https://arnob666666-mentormind-ml.hf.space/v1/tutor/answer
ML_API_KEY=mentormind-public-demo-ml-key
TUTOR_MODEL_TIMEOUT_SECONDS=60

# --- CORS (add your Vercel URL + localhost for Capacitor APK) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202,https://localhost,capacitor://localhost,https://mentormind-demo.vercel.app,https://mentormind-studio.vercel.app

# --- Email: console only (free). Do not set SMTP. ---

# --- Object storage: local disk (free). Do not set R2_* / S3 vars. ---

# --- Payments: simulated checkout at POST /api/v1/auth/subscribe/ ---
# No Stripe keys anywhere — premium is activated instantly in the DB.
